{
  "name": "jupyterlab-pegasus",
  "version": "0.1.0",
  "description": "Pegasus WMS interactive cell for JupyterLab",
  "keywords": [
    "jupyter",
    "jupyterlab",
    "jupyterlab-extension",
    "pegasus"
  ],
  "license": "Apache-2.0",
  "main": "lib/index.js",
  "types": "lib/index.d.ts",
  "style": "style/pegasus.css",
  "files": [
    "lib/**/*.{d.ts,js,js.map}",
    "style/**/*.css",
    "schema/**/*.json",
    "jupyterlab_pegasus/labextension/**"
  ],
  "jupyterlab": {
    "extension": true,
    "outputDir": "jupyterlab_pegasus/labextension",
    "schemaDir": "schema",
    "_build": {
      "load": "static/remoteEntry.407a2731d6fcea5d8524.js",
      "extension": "./extension",
      "style": "./style"
    }
  },
  "scripts": {
    "build": "npm run build:lib && npm run build:labextension",
    "build:lib": "tsc --sourceMap",
    "build:lib:prod": "tsc",
    "build:labextension": "jupyter labextension build .",
    "clean:lib": "rimraf lib tsconfig.tsbuildinfo",
    "clean:labextension": "rimraf jupyterlab_pegasus/labextension/static",
    "watch:src": "tsc -w --sourceMap",
    "watch:labextension": "jupyter labextension watch ."
  },
  "dependencies": {
    "@jupyterlab/application": "^4.0.0",
    "@jupyterlab/apputils": "^4.0.0",
    "@jupyterlab/cells": "^4.0.0",
    "@jupyterlab/launcher": "^4.5.8",
    "@jupyterlab/notebook": "^4.0.0",
    "@jupyterlab/settingregistry": "^4.0.0",
    "@jupyterlab/ui-components": "^4.5.8",
    "@lumino/signaling": "^2.0.0",
    "@lumino/widgets": "^2.0.0",
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/xterm": "^5.3.0",
    "react": "^18.0.0",
    "react-dom": "^18.0.0"
  },
  "devDependencies": {
    "@jupyterlab/builder": "^4.0.0",
    "@types/react": "^18.0.0",
    "@types/react-dom": "^18.0.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "rimraf": "^5.0.0",
    "typescript": "~5.0.0"
  },
  "resolutions": {
    "license-webpack-plugin": "4.0.2"
  },
  "overrides": {
    "license-webpack-plugin": "4.0.2"
  }
}
